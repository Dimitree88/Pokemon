{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --omit=dev --ignore-scripts",
  "rewrites": [
    { "source": "/((?!api/|assets/|src/|data/).*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.mjs": {
      "includeFiles": "{data,assets/energy,assets/rarity,assets/sets}/**"
    }
  }
}
